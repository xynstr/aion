# AION Configuration
# ==================
# Kopiere diese Datei zu .env und fülle deine Werte ein

# OpenAI API Key (erforderlich)
# Hol dir einen Key von: https://platform.openai.com/api/keys
OPENAI_API_KEY=sk-your-api-key-here

# Modell (optional, Standard: gpt-4.1)
AION_MODEL=gpt-4.1

# Web-Port (optional, Standard: 7000)
AION_PORT=7000

# Speicher-Pfad für Gedächtnis (optional)
# AION_MEMORY_FILE=/path/to/aion_memory.json

# Tools-Verzeichnis (optional)
# AION_TOOLS_DIR=/path/to/aion_tools
