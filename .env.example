# AION Konfiguration
# ===================
# Kopiere diese Datei zu .env und trage deine Werte ein.
# Nur OPENAI_API_KEY oder GEMINI_API_KEY ist Pflicht — der Rest ist optional.

# ── KI-Provider (mindestens einer erforderlich) ────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ── Modell (optional, Standard: gpt-4.1) ──────────────────────────────────────
# Wird durch config.json überschrieben wenn ein Modell per UI gewählt wurde.
# OpenAI:  gpt-4.1 | gpt-4o | o3 | o4-mini
# Gemini:  gemini-2.5-pro | gemini-2.5-flash | gemini-2.0-flash
AION_MODEL=gpt-4.1

# ── Web-Server ─────────────────────────────────────────────────────────────────
AION_PORT=7000

# ── Telegram (optional) ───────────────────────────────────────────────────────
# Bot erstellen: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
